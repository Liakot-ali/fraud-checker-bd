# MongoDB Atlas Connection String (required)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp

# Database Name
DB_NAME=fraud_checker_db

# Server Port
PORT=3000

# Secret for signing admin JWTs (REQUIRED in production — the app refuses to
# start in production without it). Generate one with:  openssl rand -hex 48
JWT_SECRET=

# First-admin seed credentials. In production the app refuses to seed a default
# password, so set these before the first run. (In development, if ADMIN_PASSWORD
# is empty, a dev-only admin/admin123 is seeded and you are forced to change it.)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Canonical public origin for sitemap / share (OG) / canonical URLs. If unset,
# the request Host header is used (development only). e.g. https://fraudcheck.example
BASE_URL=

# Set to 'production' in real deployments (enables the hard-fail safety checks).
NODE_ENV=

# Set to 'true' ONLY to seed demo/sample data into an empty database.
SEED_SAMPLE=
